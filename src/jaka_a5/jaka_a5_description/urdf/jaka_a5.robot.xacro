<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="jaka_a5">

  <!-- Constants -->
  <xacro:property name="PI" value="3.1415926535897931" />
  <xacro:property name="VELOCITY" value="3.665" />

  <link name="world" />

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0028167 -0.00019454 0.019544" rpy="0 0 0" />
      <mass value="0.52663" />
      <inertia ixx="0.0006297" ixy="6.7091E-08" ixz="3.4682E-06"
               iyy="0.00095727" iyz="2.4476E-07" izz="0.0014514" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/base_link.STL" />
      </geometry>
      <material name="">
        <color rgba="0.86667 0.86667 0.8902 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- World to Base Joint -->
  <joint name="fixed" type="fixed">
    <parent link="world" />
    <child link="base_link" />
  </joint>

  <!-- Joint 1 -->
  <link name="J1">
    <inertial>
      <origin xyz="-2.5186E-07 0.0033226 -0.001509" rpy="0 0 0" />
      <mass value="15.135" />
      <inertia ixx="0.044302" ixy="1.5349E-07" ixz="-6.1966E-07"
               iyy="0.043091" iyz="1.4326E-05" izz="0.030523" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J1.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J1.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_1" type="revolute">
    <origin xyz="0 -0.00022535 0.12015" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="J1" />
    <axis xyz="0 0 1" />
    <limit lower="-6.28" upper="6.28" effort="2000" velocity="3.665" />
  </joint>

  <!-- Joint 2 -->
  <link name="J2">
    <inertial>
      <origin xyz="0.215 4.9016E-09 -0.14314" rpy="0 0 0" />
      <mass value="5.7891" />
      <inertia ixx="0.013095" ixy="-4.1856E-09" ixz="2.9241E-08"
               iyy="0.20279" iyz="2.1723E-09" izz="0.19928" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J2.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J2.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_2" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 0 0" />
    <parent link="J1" />
    <child link="J2" />
    <axis xyz="0 0 1" />
    <limit lower="-1.48" upper="4.628" effort="5000" velocity="3.665" />
  </joint>

  <!-- Joint 3 -->
  <link name="J3">
    <inertial>
      <origin xyz="0.17601 -7.8489E-07 -0.0097984" rpy="0 0 0" />
      <mass value="2.5808" />
      <inertia ixx="0.0032112" ixy="1.1156E-07" ixz="-0.0022739"
               iyy="0.05921" iyz="3.3121E-08" izz="0.058511" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J3.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J3.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_3" type="revolute">
    <origin xyz="0.43 0 0" rpy="0 0 0" />
    <parent link="J2" />
    <child link="J3" />
    <axis xyz="0 0 1" />
    <limit lower="-3.05" upper="3.05" effort="5000" velocity="3.665" />
  </joint>

  <!-- Joint 4 -->
  <link name="J4">
    <inertial>
      <origin xyz="-2.1463E-06 -0.0059512 0.0026789" rpy="0 0 0" />
      <mass value="5.5377" />
      <inertia ixx="0.0092004" ixy="1.17E-07" ixz="-1.3683E-08"
               iyy="0.0052083" iyz="-8.5741E-05" izz="0.0089125" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J4.STL" />
      </geometry>
      <material name="">
        <color rgba="0.84706 0.84706 0.84706 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J4.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_4" type="revolute">
    <origin xyz="0.3685 0 -0.115" rpy="0 0 0" />
    <parent link="J3" />
    <child link="J4" />
    <axis xyz="0 0 1" />
    <limit lower="-1.48" upper="4.62" effort="2000" velocity="3.665" />
  </joint>

  <!-- Joint 5 -->
  <link name="J5">
    <inertial>
      <origin xyz="-2.2875E-08 -0.0015344 -0.0023275" rpy="0 0 0" />
      <mass value="0.81207" />
      <inertia ixx="0.0016825" ixy="2.829E-09" ixz="-1.1984E-08"
               iyy="0.00074766" iyz="3.2415E-06" izz="0.0016452" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J5.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J5.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_5" type="revolute">
    <origin xyz="0 -0.1135 0" rpy="1.5708 -0.00010901 0" />
    <parent link="J4" />
    <child link="J5" />
    <axis xyz="0 0 1" />
    <limit lower="-6.28" upper="6.28" effort="3000" velocity="3.665" />
  </joint>

  <!-- Joint 6 (Tool Flange) -->
  <link name="J6">
    <inertial>
      <origin xyz="3.1532E-05 -1.4302E-05 -0.02023" rpy="0 0 0" />
      <mass value="1.336" />
      <inertia ixx="0.00066124" ixy="-6.979E-07" ixz="-6.4232E-07"
               iyy="0.00066646" iyz="8.1119E-07" izz="0.0010673" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J6.STL" />
      </geometry>
      <material name="">
        <color rgba="0.84706 0.84706 0.84706 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://jaka_a5_description/meshes/jaka_a5_meshes/J6.STL" />
      </geometry>
    </collision>
  </link>
  <joint name="joint_6" type="revolute">
    <origin xyz="0 0.107 0" rpy="-1.5708 0 -0.00010901" />
    <parent link="J5" />
    <child link="J6" />
    <axis xyz="-0.00010901 0 1" />
    <limit lower="-6.28" upper="6.28" effort="1000" velocity="3.665" />
  </joint>

  <!-- Eye-in-Hand Camera Mount -->
  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.08" />
      <inertia ixx="1.8e-05" ixy="0.0" ixz="0.0" iyy="1.8e-05" iyz="0.0" izz="1.2e-05" />
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.03 0.03" />
      </geometry>
      <material name="camera_body">
        <color rgba="0.1 0.1 0.1 1.0" />
      </material>
    </visual>
    <visual>
      <origin xyz="0.024 0.0 0.0" rpy="0 1.5708 0" />
      <geometry>
        <cylinder radius="0.009" length="0.01" />
      </geometry>
      <material name="camera_lens">
        <color rgba="0.25 0.45 0.8 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
      <geometry>
        <box size="0.045 0.03 0.03" />
      </geometry>
    </collision>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.055 0 0.045" rpy="0 0 0" />
    <parent link="J6" />
    <child link="camera_link" />
  </joint>

  <link name="camera_optical_frame" />

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679" />
    <parent link="camera_link" />
    <child link="camera_optical_frame" />
  </joint>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="joint_1">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.20943951023931953</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint_2">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">1.9198621771937625</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint_3">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">-2.181661564992912</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint_4">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.3141592653589793</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint_5">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.22689280275926285</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
    <joint name="joint_6">
      <command_interface name="position" />
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity" />
    </joint>
  </ros2_control>

  <!-- ROS2 control transmission - repeat for all 6 joints -->
  <transmission name="trans_joint_1">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_1">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_1_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="trans_joint_2">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_2">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_2_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="trans_joint_3">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_3">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_3_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="trans_joint_4">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_4">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_4_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="trans_joint_5">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_5">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_5_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>
  <transmission name="trans_joint_6">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="joint_6">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
    </joint>
    <actuator name="joint_6_motor">
      <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

</robot>
