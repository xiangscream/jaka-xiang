Panels:
  - Class: rviz_common/DragTeleop
    Name: Drag Teleop
  - Class: rviz_common/Views
    Expanded:
      - Class: rviz_default_view/TF
      - Class: rviz_default_view/Orbit
        Name: Orbit
    Name: Views
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 100
      Reference Frame: world
      Value: true
    - Class: moveit_ros_visualization/RobotStateDisplay
      Name: RobotState
      Robot Description: robot_description
      Robot State Topic:
        Value: /robot_state
      TF Prefix: ""
      Links:
        base_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J1:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J2:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J3:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J4:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J5:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        J6:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        tool0:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
      Update Interval: 0
      Value: true
    - Class: moveit_ros_visualization/MotionPlanning
      Enabled: true
      Name: MotionPlanning
      Planned Path:
        Color Enabled: false
        Enabled: true
        Interrupt Display: false
        Links:
          All Links Enabled: true
          Expand Joint Details: false
          Expand Link Details: false
          Show Trail: false
          Show Workspace: false
          State Display Time: 0.05 s
          Trail Step Size: 1
          Value: true
        Loop Animation: true
        Planned Path:
          Interrupt Display: false
          Links:
            All Links Enabled: true
            Expand Joint Details: false
            Expand Link Details: false
            Show Trail: false
            Show Workspace: false
            Value: true
          Publish Debug Info: false
          Robot Model Enabled: true
          Robot Color: 150; 50; 150; 255
          Show Robot Collision: false
          Show Robot Visual: true
          Show Trails: false
          State Display Time: 0.05 s
          Trail Step Size: 1
          Value: true
        Provider: OMPL
        Request: Planning Query
          Goal Constraints: []
          Group: jaka_a5
          Planner ID: ""
          Planning Pipeline: ompl
          Planning Time: 1 s
          Range: 0 m
          Relaxed Goal: false
          Start State: Use Current State
          Velocity Scale: 1
        Scene Geometry:
          Planning Scene:
            Show Collision Geometry: false
            Show Octomap: false
            Show Unknown: false
            Value: true
          Scene Robot:
            Show Attached Objects: false
            Show Robot Collision: false
            Show Robot Visual: true
            Value: true
      Name: MotionPlanning
      Robot Description: robot_description
      Scene Graph:
        Scene Robot:
          Show Robot Collision: false
          Show Robot Visual: true
          Value: true
      Planning Scene Topic: /moveit/motion_plan_fixed_path_traj_controller
      RViz Preview:
        Loop Animation: true
        Show Trails: false
        State Display Time: 0.05 s
        Trail Step Size: 1
        Value: true
      Value: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: world
    Frame Rate: 30 Hz
  Name: root
  Tools:
    - Class: moveit_ros_visualization/MoveitInteractiveMarkerMenu
      Name: MoveItInteractiveMarkerMenu
    - Class: moveit_ros_visualization/MoveItPosePanel
      Name: MoveItPosePanel
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Name: Orbit
      Restore Frame: false
      Target Frame: world
      Value: Orbit
    Saved: []
